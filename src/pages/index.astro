---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="WingChun's Website">
  <div class="profile-container">
    <section class="hero-section">
      <fluent-text block size="700" weight="bold">WingChunWong</fluent-text>
      <fluent-text block size="300" class="hero-subtitle">A student from Hong Kong</fluent-text>
    </section>

    <section class="info-cards">
      <div class="info-card">
        <div class="info-card-icon"><i class="bi bi-code-slash"></i></div>
        <div class="info-card-content">
          <fluent-label weight="semibold" size="small">Current Project</fluent-label>
          <fluent-text block size="300">Building <fluent-link href="https://github.com/ChouChiu/My-WebSite" target="_blank">My Website</fluent-link>,<fluent-link href="https://github.com/LanRhyme/MicYou" target="_blank">MicYou</fluent-link>and<fluent-link href="https://github.com/LanRhyme/Website-MicYou" target="_blank">Website-MicYou</fluent-link></fluent-text>
        </div>
      </div>
      <div class="info-card">
        <div class="info-card-icon"><i class="bi bi-chat-dots"></i></div>
        <div class="info-card-content">
          <fluent-label weight="semibold" size="small">Interests</fluent-label>
          <fluent-text block size="300">Vibe Coding &amp; Play Games</fluent-text>
        </div>
      </div>
    </section>
    
    <section class="contact-section">
      <fluent-label weight="semibold" class="section-title">Contact</fluent-label>
      <div class="contact-links">
        <fluent-anchor-button href="https://t.me/wingchunwong111" target="_blank" appearance="outline" shape="circular">
          <i class="bi bi-telegram" slot="start"></i>
          Telegram
        </fluent-anchor-button>
        <fluent-anchor-button href="mailto:lshengevery@gmail.com" appearance="outline" shape="circular">
          <i class="bi bi-envelope-fill" slot="start"></i>
          Gmail
        </fluent-anchor-button>
        <fluent-button appearance="outline" shape="circular" id="qq-copy" data-qq="2750821684">
          <i class="bi bi-chat-square-fill" slot="start"></i>
          QQ: 2750821684
        </fluent-button>
      </div>
    </section>

    <section class="stats-section">
      <fluent-label weight="semibold" class="section-title">GitHub Stats</fluent-label>
      <div class="stats-unified-card">
        <div class="stats-grid">
          <div class="stats-item">
            <img
              src="https://grs.wing111.dpdns.org/api?username=ChouChiu&layout=compact&theme=dark&show_icons=true&bg_color=00000000&border_color=00000000&hide_border=true&title_color=b8b8c0&text_color=8e8e98&icon_color=7ca6c4"
              alt="wingchunwong stats"
            />
          </div>
          <div class="stats-item">
            <img
              src="https://grs.wing111.dpdns.org/api/top-langs/?username=ChouChiu&layout=compact&theme=dark&show_icons=true&bg_color=00000000&border_color=00000000&hide_border=true&title_color=b8b8c0&text_color=8e8e98&icon_color=7ca6c4"
              alt="wingchunwong toplangs"
            />
          </div>
          <div class="stats-item">
            <img
              src="https://github-readme-streak-stats.herokuapp.com/?user=ChouChiu&theme=dark&background=00000000&border=00000000&stroke=00000000&ring=7ca6c4&fire=7ca6c4&currStreakLabel=b8b8c0&sideLabels=b8b8c0&currStreakNum=e3e3e8&sideNums=e3e3e8&dates=6c6c76"
              alt="GitHub Streak"
            />
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .profile-container {
    max-width: 860px;
    width: 100%;
    margin: 0;
  }

  /* ── Hero ── */
  .hero-section {
    margin-bottom: 32px;
  }

  .hero-subtitle {
    color: var(--colorNeutralForeground3);
    margin-top: 4px;
  }

  .section-title {
    display: block;
    color: var(--colorNeutralForeground2);
    margin-bottom: 12px;
  }

  /* ── Info Cards ── */
  .info-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 12px;
    margin-bottom: 28px;
  }

  .info-card {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 16px;
    background: var(--colorNeutralBackground3);
    border: 1px solid var(--colorNeutralStroke2);
    border-radius: var(--borderRadiusLarge);
    transition: border-color var(--durationNormal) var(--curveEasyEase);
  }

  .info-card:hover {
    border-color: var(--colorNeutralStroke1);
  }

  .info-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--borderRadiusMedium);
    background: var(--colorBrandStroke2);
    color: var(--colorBrandForeground1);
    font-size: 16px;
    flex-shrink: 0;
  }

  .info-card-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .info-card-content fluent-text {
    color: var(--colorNeutralForeground3);
  }

  /* ── Contact ── */
  .contact-section {
    margin-bottom: 28px;
  }

  .contact-links {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .contact-links i {
    font-size: 14px;
  }

  /* ── Stats ── */
  .stats-unified-card {
    background: var(--colorNeutralBackground3);
    border: 1px solid var(--colorNeutralStroke2);
    border-radius: var(--borderRadiusLarge);
    padding: 12px 14px;
    transition: border-color var(--durationNormal) var(--curveEasyEase);
  }

  .stats-unified-card:hover {
    border-color: var(--colorNeutralStroke1);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    align-items: stretch;
  }

  .stats-item {
    min-width: 0;
  }

  .stats-grid img {
    display: block;
    width: 100%;
    height: 148px;
    object-fit: contain;
    border-radius: var(--borderRadiusMedium);
  }

  @media (max-width: 980px) {
    .stats-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .hero-section h1 {
      font-size: 24px;
    }

    .info-cards {
      grid-template-columns: 1fr;
    }

    .stats-grid {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .stats-unified-card {
      padding: 10px;
    }

    .stats-grid img {
      height: 140px;
      max-width: 100%;
    }
  }

  @media (max-width: 420px) {
    .contact-links {
      gap: 6px;
    }

    .stats-grid img {
      height: 130px;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const qqBtn = document.getElementById("qq-copy");
    if (qqBtn) {
      qqBtn.addEventListener("click", async () => {
        const qq = qqBtn.dataset.qq;
        if (!qq) return;
        try {
          await navigator.clipboard.writeText(qq);
          // Feedback: change text temporarily
          const span = qqBtn.querySelector("span");
          if (!span) return;
          const originalText = span.textContent;
          span.textContent = "Copied!";
          setTimeout(() => {
            span.textContent = originalText;
          }, 2000);
        } catch (err) {
          console.error("Failed to copy QQ number:", err);
        }
      });
    }
  });
</script>
