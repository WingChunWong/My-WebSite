---
import GitHubTimeline from "../components/GitHubTimeline.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { fetchGitHubContributions, type TimelineEvent } from "../lib/github";

const GITHUB_USERNAME = "wingchunwong";
const token = import.meta.env.GH_TOKEN;
const SINCE_DATE = new Date("2020-01-01"); // 从更早的时间开始获取

let events: TimelineEvent[] = [];

if (token) {
  try {
    console.log(
      `Fetching GitHub contributions for ${GITHUB_USERNAME} since ${SINCE_DATE.toISOString()}`,
    );
    events = await fetchGitHubContributions(token, GITHUB_USERNAME, SINCE_DATE);
    console.log(`Fetched ${events.length} total events`);

    // 打印日期范围统计
    if (events.length > 0) {
      const dates = events.map((e) => new Date(e.date).getTime());
      const earliest = new Date(Math.min(...dates));
      const latest = new Date(Math.max(...dates));
      console.log(
        `Date range: ${earliest.toISOString().split("T")[0]} to ${latest.toISOString().split("T")[0]}`,
      );

      // 按年份统计
      const byYear = new Map<number, number>();
      for (const event of events) {
        const year = new Date(event.date).getFullYear();
        byYear.set(year, (byYear.get(year) || 0) + 1);
      }
      console.log("Events by year:", Object.fromEntries(byYear));
    }
  } catch (error) {
    console.error("Failed to fetch GitHub contributions:", error);
  }
} else {
  console.warn("GH_TOKEN not set — GitHub timeline will be empty");
}

const buildTime = new Date().toLocaleDateString("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
  hour: "2-digit",
  minute: "2-digit",
});
---

<BaseLayout title="GitHub 贡献">
  <GitHubTimeline events={events} buildTime={buildTime} />
</BaseLayout>
