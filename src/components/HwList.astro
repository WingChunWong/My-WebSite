---
import type { HwItem } from "../lib/homework";

interface Props {
  data: HwItem[];
  subjects: string[];
  initialDate: string;
  isDataLoaded: boolean;
}

const { data, subjects, initialDate, isDataLoaded } = Astro.props;
---

<!-- Loading spinner -->
<div id="hw-loading" style="display:flex;align-items:center;justify-content:center;min-height:300px;gap:8px;color:var(--colorNeutralForeground3);">
  <fluent-spinner></fluent-spinner>
  <span>加載中…</span>
</div>

<!-- Main UI - always rendered, visibility controlled by CSS/JS -->
<div id="hw-root" class="hidden-on-load">
  <!-- Page Header -->
  <div class="page-header">
    <h2>作業列表</h2>
    <fluent-button id="btn-download" appearance="outline">下載圖片</fluent-button>
  </div>

  <!-- Filters -->
  <div class="filters-grid">
    <div class="filter-item">
      <fluent-label>發佈日期</fluent-label>
      <input type="date" class="filter-input" id="filter-date" value={initialDate} />
    </div>
    <div class="filter-item">
      <fluent-label>科目</fluent-label>
      <select class="filter-input" id="filter-subject">
        <option value="">全部</option>
        {subjects.map((s) => <option value={s}>{s}</option>)}
      </select>
    </div>
    <div class="filter-item">
      <fluent-label>截止狀態</fluent-label>
      <select class="filter-input" id="filter-status">
        <option value="">全部</option>
        <option value="overdue">已過期</option>
        <option value="today">今天到期</option>
        <option value="future">未來</option>
      </select>
    </div>
  </div>

  <!-- Actions -->
  <div class="actions-row">
    <fluent-button id="btn-reset" appearance="outline">重置篩選</fluent-button>
    <div id="upload-area" class="upload-area">
      <input type="file" id="file-upload" accept="application/json" />
    </div>
  </div>

  <!-- Stats -->
  <div class="stat-grid">
    <div class="stat-item">
      <div class="stat-content">
        <i class="bi bi-journal-plus stat-icon"></i>
        <div>
          <div class="stat-title">發布功課</div>
          <div class="stat-value" id="stat-issued">0</div>
        </div>
      </div>
    </div>
    <div class="stat-item">
      <div class="stat-content">
        <i class="bi bi-clock stat-icon"></i>
        <div>
          <div class="stat-title">截止功課</div>
          <div class="stat-value" id="stat-due">0</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Table -->
  <div class="table-card">
    <div class="table-scroll">
      <table id="hw-table" class="hw-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>科目</th>
            <th>作業</th>
            <th>發佈</th>
            <th>截止</th>
            <th>班級</th>
            <th>狀態</th>
            <th>備註</th>
          </tr>
        </thead>
        <tbody id="hw-tbody"></tbody>
      </table>
    </div>
  </div>
</div>

<script define:vars={{ data, subjects, initialDate, isDataLoaded }}>
  // Inline server data into client
  window.__hwData = { items: data, subjects, initialDate, isDataLoaded };
</script>

<script>
  import html2canvas from "html2canvas";
  import {
    countDueBy,
    countIssuedBy,
    extractSubjects,
    filterHomework,
    getHomeworkStatus,
    type HwItem,
    isHwArray,
  } from "../lib/homework";

  const hw = (window as any).__hwData as {
    items: HwItem[];
    subjects: string[];
    initialDate: string;
    isDataLoaded: boolean;
  };

  let items: HwItem[] = hw.items;
  let currentSubjects: string[] = hw.subjects;

  const filterDate = document.getElementById("filter-date") as HTMLInputElement | null;
  const filterSubject = document.getElementById("filter-subject") as HTMLSelectElement | null;
  const filterStatus = document.getElementById("filter-status") as HTMLSelectElement | null;
  const tbody = document.getElementById("hw-tbody") as HTMLTableSectionElement | null;
  const statIssued = document.getElementById("stat-issued");
  const statDue = document.getElementById("stat-due");
  const btnReset = document.getElementById("btn-reset");
  const btnDownload = document.getElementById("btn-download");
  const fileUpload = document.getElementById("file-upload") as HTMLInputElement | null;
  const uploadArea = document.getElementById("upload-area");
  const hwTable = document.getElementById("hw-table") as HTMLTableElement | null;
  const hwRoot = document.getElementById("hw-root");
  const hwLoading = document.getElementById("hw-loading");

  // Helper function to escape HTML special characters
  function escapeHtml(text: string): string {
    const map: { [key: string]: string } = {
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#039;",
    };
    return text.replace(/[&<>"']/g, (c) => map[c]);
  }

  function updateUIVisibility() {
    // Show hw-root and hide hw-loading if data is available, otherwise show loading
    const hasData = items.length > 0;
    if (hwRoot) hwRoot.classList.toggle("hidden-on-load", !hasData);
    if (hwLoading) hwLoading.style.display = hasData ? "none" : "flex";
  }

  function getStatusHTML(dueDateStr: string) {
    const s = getHomeworkStatus(dueDateStr);
    return `<span class="status-badge ${s.cls}"><i class="bi bi-${s.icon}"></i><span>${escapeHtml(s.text)}</span></span>`;
  }

  function renderTable() {
    if (!tbody || !filterDate) return;
    const issueDate = filterDate.value;
    const subject = filterSubject?.value || "";
    const dueStatus = filterStatus?.value || "";

    const filtered = filterHomework(items, {
      issueDate,
      subject,
      dueStatus: dueStatus as "overdue" | "today" | "future" | undefined || undefined,
    });

    tbody.innerHTML = filtered
      .map((it) => {
        const s = getHomeworkStatus(it.due_date);
        const id = escapeHtml(String(it.id));
        const subj = escapeHtml(it.subject);
        const hw_name = escapeHtml(it.homework_name);
        const issue = escapeHtml(it.issue_date);
        const due = escapeHtml(it.due_date);
        const cls = escapeHtml(it.class_group || "");
        const rem = escapeHtml(it.remarks || "無備註");
        return `<tr class="${s.cls}">
          <td>${id}</td>
          <td>${subj}</td>
          <td>${hw_name}</td>
          <td>${issue}</td>
          <td>${due}</td>
          <td>${cls}</td>
          <td>${getStatusHTML(it.due_date)}</td>
          <td><div class="remarks-cell">${rem}</div></td>
        </tr>`;
      })
      .join("");

    // Update stats
    if (statIssued) statIssued.textContent = String(countIssuedBy(items, issueDate));
    if (statDue) statDue.textContent = String(countDueBy(items, issueDate));
  }

  function updateSubjectOptions() {
    if (!filterSubject) return;
    const current = filterSubject.value;
    filterSubject.innerHTML = `<option value="">全部</option>` +
      currentSubjects
        .map(
          (s) =>
            `<option value="${escapeHtml(s)}"${s === current ? " selected" : ""}>${escapeHtml(s)}</option>`
        )
        .join("");
  }

  // Filter listeners
  filterDate?.addEventListener("input", renderTable);
  filterSubject?.addEventListener("change", renderTable);
  filterStatus?.addEventListener("change", renderTable);

  // Reset
  btnReset?.addEventListener("click", () => {
    if (filterDate) filterDate.value = new Date().toISOString().split("T")[0];
    if (filterSubject) filterSubject.value = "";
    if (filterStatus) filterStatus.value = "";
    renderTable();
  });

  // File upload
  fileUpload?.addEventListener("change", (e) => {
    const input = e.target as HTMLInputElement;
    const f = input.files?.[0];
    if (!f) return;
    const reader = new FileReader();
    reader.onload = () => {
      try {
        const parsed = JSON.parse(String(reader.result)) as unknown;
        const parsedObj = parsed as { items?: unknown };
        if (isHwArray(parsed)) items = parsed;
        else if (parsedObj.items && isHwArray(parsedObj.items)) items = parsedObj.items;
        else throw new Error("數據格式不正確");

        currentSubjects = extractSubjects(items);
        updateSubjectOptions();
        if (uploadArea) uploadArea.style.display = "none";
        updateUIVisibility();
        renderTable();
      } catch (err: unknown) {
        const message = err instanceof Error ? err.message : String(err);
        alert(`解析文件失敗：${message}`);
      }
    };
    reader.readAsText(f);
  });

  // Screenshot download
  btnDownload?.addEventListener("click", async () => {
    try {
      const targetYmd = filterDate?.value || "";
      const targetZh = new Date(targetYmd).toLocaleDateString("zh-Hant", {
        year: "numeric",
        month: "long",
        day: "numeric",
        weekday: "long",
      });

      const temp = document.createElement("div");
      temp.style.position = "fixed";
      temp.style.left = "-9999px";
      temp.style.top = "-9999px";
      temp.style.width = "1200px";
      temp.style.padding = "20px";
      temp.style.background =
        getComputedStyle(document.body).getPropertyValue("--colorNeutralBackground2") || "#111111";

      const header = document.createElement("div");
      header.innerHTML = `<h2 style="margin:0 0 8px;color:${getComputedStyle(document.body).getPropertyValue("--colorBrandForeground1") || "#479ef5"}">功課表</h2><div style="color:var(--colorNeutralForeground2)">${escapeHtml(targetZh)}</div>`;
      temp.appendChild(header);

      if (hwTable) {
        const clone = hwTable.cloneNode(true) as HTMLElement;
        clone.style.width = "100%";
        temp.appendChild(clone);
      } else {
        throw new Error("找不到表格元素");
      }

      document.body.appendChild(temp);
      await new Promise((r) => setTimeout(r, 80));
      const canvas = await html2canvas(temp as HTMLElement, { scale: 3, useCORS: true });
      const link = document.createElement("a");
      link.download = `功課表_${targetYmd.replace(/-/g, "")}.png`;
      link.href = canvas.toDataURL("image/png");
      document.body.appendChild(link);
      link.click();
      link.remove();
      temp.remove();
    } catch (err: unknown) {
      const message = err instanceof Error ? err.message : String(err);
      alert(`生成圖片失敗：${message}`);
    }
  });

  // Set initial visibility state and render
  updateUIVisibility();
  renderTable();
</script>

<style>
  .hidden-on-load {
    display: none;
  }

  .page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }
  .page-header h2 {
    margin: 0;
    animation: slideInLeft 300ms cubic-bezier(0, 0, 0, 1) both;
  }

  .filters-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 16px;
    animation: slideUp 300ms cubic-bezier(0, 0, 0, 1) both;
    animation-delay: 50ms;
  }
  .filter-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .filter-input {
    width: 100%;
    padding: 8px 12px;
    background: var(--colorNeutralBackground4, #333);
    border: none;
    border-bottom: 2px solid var(--colorNeutralStroke1, #404040);
    color: var(--colorNeutralForeground1, #fff);
    font-family: inherit;
    font-size: 14px;
    border-radius: 4px 4px 0 0;
    appearance: none;
    -webkit-appearance: none;
    transition: border-color 100ms ease;
  }
  .filter-input:focus {
    outline: none;
    border-bottom-color: var(--colorBrandForeground1, #479ef5);
  }

  .actions-row {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
    align-items: center;
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
    margin-bottom: 16px;
    animation: slideUp 300ms cubic-bezier(0, 0, 0, 1) both;
    animation-delay: 100ms;
  }
  .stat-item {
    padding: 16px;
    background: var(--colorNeutralBackground2, #1b1b1b);
    border: 1px solid var(--colorNeutralStroke2, #333);
    border-radius: 12px;
    box-shadow: 0 0 2px rgba(0,0,0,0.24), 0 2px 4px rgba(0,0,0,0.28);
  }
  .stat-content {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .stat-icon {
    font-size: 22px;
    color: var(--colorBrandForeground1, #479ef5);
  }
  .stat-title {
    font-size: 12px;
    color: var(--colorNeutralForeground3, #adadad);
    font-weight: 500;
  }
  .stat-value {
    font-size: 24px;
    font-weight: 700;
    color: var(--colorNeutralForeground1, #fff);
  }

  .table-card {
    padding: 0;
    overflow: hidden;
    background: var(--colorNeutralBackground2, #1b1b1b);
    border: 1px solid var(--colorNeutralStroke2, #333);
    border-radius: 12px;
    box-shadow: 0 0 2px rgba(0,0,0,0.24), 0 2px 4px rgba(0,0,0,0.28);
    animation: slideUp 300ms cubic-bezier(0, 0, 0, 1) both;
    animation-delay: 150ms;
  }
  .table-scroll {
    overflow-x: auto;
  }
  .hw-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }
  .hw-table th {
    background: var(--colorNeutralBackground3, #282828);
    color: var(--colorNeutralForeground2, #d6d6d6);
    font-weight: 600;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 12px 16px;
    text-align: left;
    border-bottom: 1px solid var(--colorNeutralStroke1, #404040);
    white-space: nowrap;
    position: sticky;
    top: 0;
    z-index: 2;
  }
  .hw-table :global(td) {
    padding: 10px 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.053);
    color: var(--colorNeutralForeground2, #d6d6d6);
    vertical-align: middle;
  }
  .hw-table :global(tbody tr) {
    transition: background 100ms ease;
  }
  .hw-table :global(tbody tr:nth-child(even)) {
    background: rgba(255, 255, 255, 0.053);
  }
  .hw-table :global(tbody tr:hover) {
    background: rgba(255, 255, 255, 0.06);
  }
  .hw-table :global(tbody tr.overdue) {
    background: rgba(196, 49, 75, 0.1);
  }
  .hw-table :global(tbody tr.overdue:hover) {
    background: rgba(196, 49, 75, 0.14);
  }
  .hw-table :global(tbody tr.today) {
    background: rgba(71, 158, 245, 0.05);
  }
  .hw-table :global(tbody tr.today:hover) {
    background: rgba(71, 158, 245, 0.09);
  }

  :global(.status-badge) {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    border-radius: 4px;
    min-width: 88px;
    justify-content: center;
    font-size: 12px;
    font-weight: 600;
    white-space: nowrap;
    border: 1px solid transparent;
  }
  :global(.status-badge i) {
    font-size: 12px;
  }
  :global(.status-badge.overdue) {
    background: rgba(196, 49, 75, 0.1);
    color: var(--colorPaletteRedForeground1, #dc626d);
    border-color: rgba(220, 98, 109, 0.18);
  }
  :global(.status-badge.today) {
    background: rgba(71, 158, 245, 0.1);
    color: var(--colorBrandForeground1, #479ef5);
    border-color: rgba(71, 158, 245, 0.32);
  }
  :global(.status-badge.normal) {
    background: transparent;
    color: var(--colorNeutralForeground3, #adadad);
    border-color: var(--colorNeutralStroke2, #333);
  }

  :global(.remarks-cell) {
    max-width: 180px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--colorNeutralForeground3, #adadad);
  }
  :global(.remarks-cell:hover) {
    white-space: normal;
    overflow: visible;
  }

  @media (max-width: 768px) {
    .filters-grid {
      grid-template-columns: 1fr;
    }
    .stat-grid {
      grid-template-columns: 1fr;
    }
    .page-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
    .hw-table :global(td),
    .hw-table th {
      padding: 8px;
      font-size: 12px;
    }
  }
</style>
