---
import type { TimelineEvent } from "../lib/github";

interface Props {
  events: TimelineEvent[];
  buildTime: string;
}

const { events, buildTime } = Astro.props;

// Group events by month
const grouped = new Map<string, TimelineEvent[]>();
for (const event of events) {
  const date = new Date(event.date);
  const key = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, "0")}`;
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key)?.push(event);
}

const monthNames = [
  "一月",
  "二月",
  "三月",
  "四月",
  "五月",
  "六月",
  "七月",
  "八月",
  "九月",
  "十月",
  "十一月",
  "十二月",
];

const formatMonth = (key: string) => {
  const [year, month] = key.split("-");
  return `${year} 年 ${monthNames[+month - 1]}`;
};

const formatDate = (dateStr: string) => {
  const d = new Date(dateStr);
  return `${d.getMonth() + 1}/${d.getDate()}`;
};

const typeConfig: Record<string, { icon: string; label: string }> = {
  commit: { icon: "bi-git", label: "提交" },
  pr: { icon: "bi-arrow-left-right", label: "Pull Request" },
  issue: { icon: "bi-record-circle", label: "Issue" },
  review: { icon: "bi-eye", label: "代码审查" },
  repo: { icon: "bi-plus-circle", label: "创建仓库" },
};

// Calculate statistics
const stats = {
  total: events.length,
  commit: events.filter((e) => e.type === "commit").length,
  pr: events.filter((e) => e.type === "pr").length,
  issue: events.filter((e) => e.type === "issue").length,
  repo: events.filter((e) => e.type === "repo").length,
};
---

<div class="timeline-container">
  <div class="timeline-header">
    <fluent-text block size="700" weight="bold">贡献时间线</fluent-text>
    <fluent-text block size="200" class="build-time">
      数据更新于 {buildTime}
    </fluent-text>
  </div>

  {events.length === 0 ? (
    <div class="timeline-empty">
      <i class="bi bi-inbox"></i>
      <fluent-text block size="400">暂无贡献数据</fluent-text>
    </div>
  ) : (
    <>
      <div class="stats-cards">
        <div class="stat-card stat-total">
          <div class="stat-value">{stats.total}</div>
          <div class="stat-label">总活动数</div>
        </div>
        <div class="stat-card stat-commit">
          <i class="bi bi-git"></i>
          <div class="stat-info">
            <div class="stat-value">{stats.commit}</div>
            <div class="stat-label">提交</div>
          </div>
        </div>
        <div class="stat-card stat-pr">
          <i class="bi bi-arrow-left-right"></i>
          <div class="stat-info">
            <div class="stat-value">{stats.pr}</div>
            <div class="stat-label">PR</div>
          </div>
        </div>
        <div class="stat-card stat-issue">
          <i class="bi bi-record-circle"></i>
          <div class="stat-info">
            <div class="stat-value">{stats.issue}</div>
            <div class="stat-label">Issue</div>
          </div>
        </div>
        <div class="stat-card stat-repo">
          <i class="bi bi-plus-circle"></i>
          <div class="stat-info">
            <div class="stat-value">{stats.repo}</div>
            <div class="stat-label">仓库</div>
          </div>
        </div>
      </div>

      <div class="timeline">
      {[...grouped.entries()].map(([monthKey, monthEvents], groupIdx) => (
        <div class="timeline-month" style={`--group-index: ${groupIdx}`}>
          <div class="month-label">
            <fluent-badge appearance="tint" color="brand">{formatMonth(monthKey)}</fluent-badge>
          </div>

          <div class="month-events">
            {monthEvents.map((event, idx) => (
              <div class="timeline-event" data-type={event.type} style={`--item-index: ${idx}`}>
                <div class="event-dot-wrapper">
                  <div class="event-dot" />
                  <div class="event-line" />
                </div>
                <div class="event-card">
                  <div class="event-meta">
                    <span class={`event-type type-${event.type}`}>
                      <i class={`bi ${typeConfig[event.type].icon}`} />
                      {typeConfig[event.type].label}
                    </span>
                    <span class="event-date">{formatDate(event.date)}</span>
                  </div>
                  {event.url ? (
                    <a href={event.url} target="_blank" rel="noopener noreferrer" class="event-title">
                      {event.title}
                    </a>
                  ) : (
                    <span class="event-title">{event.title}</span>
                  )}
                  {event.repoUrl ? (
                    <a href={event.repoUrl} target="_blank" rel="noopener noreferrer" class="event-repo">
                      <i class="bi bi-archive" />
                      {event.repo}
                    </a>
                  ) : (
                    <span class="event-repo">
                      <i class="bi bi-lock" />
                      {event.repo}
                    </span>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
      </div>
    </>
  )}
</div>

<style>
  .timeline-container {
    max-width: 720px;
    width: 100%;
  }

  /* ── Header ── */
  .timeline-header {
    margin-bottom: 32px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--colorNeutralStroke2);
  }

  .build-time {
    color: var(--colorNeutralForeground4);
    margin-top: 6px;
    font-style: italic;
  }

  /* ── Empty state ── */
  .timeline-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 64px 0;
    color: var(--colorNeutralForeground4);
    font-size: 36px;
  }

  /* ── Stats cards ── */
  .stats-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 32px;
    animation: fadeIn var(--durationNormal) var(--curveEasyEase);
  }

  .stat-card {
    background: var(--colorNeutralBackground3);
    border: 1px solid var(--colorNeutralStroke2);
    border-radius: var(--borderRadiusMedium);
    padding: 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    text-align: center;
    transition: 
      transform var(--durationFast) var(--curveEasyEase),
      border-color var(--durationFast) var(--curveEasyEase),
      background-color var(--durationFast) var(--curveEasyEase),
      box-shadow var(--durationNormal) var(--curveEasyEase);
  }

  .stat-card:hover {
    transform: translateY(-4px);
    border-color: var(--colorNeutralStroke1);
    background: var(--colorNeutralBackground2);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.12);
  }

  .stat-card i {
    font-size: 20px;
    opacity: 0.9;
    transition: transform var(--durationFast) var(--curveEasyEase);
  }

  .stat-card:hover i {
    transform: scale(1.1);
  }

  .stat-total {
    grid-column: 1 / -1;
    padding: 20px;
    gap: 6px;
    background: linear-gradient(135deg, var(--colorBrandBackground2) 0%, var(--colorNeutralBackground3) 100%);
    border-color: var(--colorBrandStroke1);
    border-radius: var(--borderRadiusLarge);
  }

  .stat-total:hover {
    transform: translateY(-4px);
    border-color: var(--colorBrandStroke1Hover);
  }

  .stat-total .stat-value {
    font-size: 40px;
    font-weight: 700;
    color: var(--colorBrandForeground1);
    line-height: 1;
  }

  .stat-total .stat-label {
    font-size: 13px;
    color: var(--colorNeutralForeground2);
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .stat-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    align-items: center;
  }

  .stat-value {
    font-size: 20px;
    font-weight: 700;
    line-height: 1;
  }

  .stat-label {
    font-size: 11px;
    color: var(--colorNeutralForeground3);
    font-weight: 500;
    letter-spacing: 0.005em;
  }

  .stat-commit i { color: var(--colorBrandForeground1); }
  .stat-commit .stat-value { color: var(--colorBrandForeground1); }
  
  .stat-pr i { color: var(--colorPaletteGreenForeground1); }
  .stat-pr .stat-value { color: var(--colorPaletteGreenForeground1); }
  
  .stat-issue i { color: var(--colorStatusWarningForeground); }
  .stat-issue .stat-value { color: var(--colorStatusWarningForeground); }
  
  .stat-repo i { color: var(--colorBrandForeground2); }
  .stat-repo .stat-value { color: var(--colorBrandForeground2); }

  /* ── Timeline structure ── */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: relative;
    margin-top: 8px;
  }

  .timeline-month {
    animation: slideUp var(--durationSlow) var(--curveDecelerateMid) both;
    animation-delay: calc(var(--group-index, 0) * 60ms);
  }

  .month-label {
    margin-bottom: 16px;
    position: sticky;
    top: 8px;
    z-index: 10;
    display: inline-block;
    backdrop-filter: blur(8px);
    padding: 2px;
    border-radius: var(--borderRadiusMedium);
  }

  .month-events {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ── Individual event ── */
  .timeline-event {
    display: flex;
    gap: 20px;
    position: relative;
    animation: fadeIn var(--durationNormal) var(--curveEasyEase) both;
    animation-delay: calc((var(--group-index, 0) * 60ms) + (var(--item-index, 0) * 30ms));
  }

  /* Dot + vertical line */
  .event-dot-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 20px;
    flex-shrink: 0;
    padding-top: 16px;
  }

  .event-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--colorNeutralStroke1);
    border: 3px solid var(--colorNeutralBackground1);
    box-shadow: 0 0 0 1px var(--colorNeutralStroke2);
    flex-shrink: 0;
    z-index: 2;
    transition: 
      transform var(--durationNormal) var(--curveEasyEase),
      box-shadow var(--durationNormal) var(--curveEasyEase);
  }

  .timeline-event:hover .event-dot {
    transform: scale(1.3);
    box-shadow: 0 0 0 3px var(--colorNeutralBackground1), 0 0 0 4px var(--colorBrandStroke1);
  }

  .event-line {
    width: 2px;
    flex-grow: 1;
    background: linear-gradient(
      to bottom,
      var(--colorNeutralStroke2) 0%,
      var(--colorNeutralStroke2) 50%,
      transparent 100%
    );
  }

  /* Last event in each month: fade out line */
  .timeline-event:last-child .event-line {
    background: transparent;
  }

  /* Dot colors by type with glow effect */
  [data-type="commit"] .event-dot { 
    background: var(--colorBrandForeground1);
    box-shadow: 0 0 0 1px var(--colorBrandStroke2), 0 0 8px var(--colorBrandForeground1);
  }
  [data-type="pr"] .event-dot { 
    background: var(--colorPaletteGreenForeground1);
    box-shadow: 0 0 0 1px var(--colorPaletteGreenForeground2), 0 0 8px var(--colorPaletteGreenForeground1);
  }
  [data-type="issue"] .event-dot { 
    background: var(--colorStatusWarningForeground);
    box-shadow: 0 0 0 1px var(--colorStatusWarningForeground), 0 0 8px rgba(255, 200, 0, 0.4);
  }
  [data-type="review"] .event-dot { 
    background: var(--colorPaletteRedForeground1);
    box-shadow: 0 0 0 1px var(--colorPaletteRedForeground2), 0 0 8px var(--colorPaletteRedForeground1);
  }
  [data-type="repo"] .event-dot { 
    background: var(--colorBrandForeground2);
    box-shadow: 0 0 0 1px var(--colorBrandStroke1), 0 0 8px var(--colorBrandForeground2);
  }

  /* ── Event card ── */
  .event-card {
    flex: 1;
    background: var(--colorNeutralBackground3);
    border: 1px solid var(--colorNeutralStroke2);
    border-radius: var(--borderRadiusLarge);
    padding: 12px 16px;
    margin-bottom: 10px;
    min-width: 0;
    position: relative;
    overflow: hidden;
    transition:
      border-color var(--durationNormal) var(--curveEasyEase),
      background-color var(--durationNormal) var(--curveEasyEase),
      transform var(--durationFast) var(--curveEasyEase),
      box-shadow var(--durationNormal) var(--curveEasyEase);
  }

  .event-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: transparent;
    transition: background var(--durationNormal) var(--curveEasyEase);
  }

  .event-card:hover {
    border-color: var(--colorNeutralStroke1Hover);
    background: var(--colorNeutralBackground2);
    transform: translateX(4px);
    box-shadow: 
      0 2px 8px rgba(0, 0, 0, 0.2),
      0 0 0 1px var(--colorNeutralStroke1);
  }

  [data-type="commit"] .event-card:hover::before { background: var(--colorBrandForeground1); }
  [data-type="pr"] .event-card:hover::before { background: var(--colorPaletteGreenForeground1); }
  [data-type="issue"] .event-card:hover::before { background: var(--colorStatusWarningForeground); }
  [data-type="review"] .event-card:hover::before { background: var(--colorPaletteRedForeground1); }
  [data-type="repo"] .event-card:hover::before { background: var(--colorBrandForeground2); }

  .event-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 8px;
  }

  .event-type {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }

  .event-type i {
    font-size: 12px;
  }

  .type-commit { color: var(--colorBrandForeground1); }
  .type-pr { color: var(--colorPaletteGreenForeground1); }
  .type-issue { color: var(--colorStatusWarningForeground); }
  .type-review { color: var(--colorPaletteRedForeground1); }
  .type-repo { color: var(--colorBrandForeground2); }

  .event-date {
    font-size: 12px;
    color: var(--colorNeutralForeground4);
    font-family: "Cascadia Code", monospace;
    flex-shrink: 0;
  }

  .event-title {
    display: block;
    font-size: 14px;
    font-weight: 500;
    color: var(--colorNeutralForeground1);
    text-decoration: none;
    line-height: 1.5;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    margin-bottom: 6px;
    transition: color var(--durationFast) var(--curveEasyEase);
  }

  a.event-title:hover {
    color: var(--colorBrandForeground1);
    text-decoration: underline;
  }

  .event-repo {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--colorNeutralForeground3);
    text-decoration: none;
    padding: 2px 6px 2px 4px;
    border-radius: var(--borderRadiusSmall);
    transition: 
      color var(--durationFast) var(--curveEasyEase),
      background var(--durationFast) var(--curveEasyEase);
  }

  a.event-repo:hover {
    color: var(--colorBrandForeground1);
    background: var(--colorNeutralBackground1);
  }

  .event-repo i {
    font-size: 11px;
    opacity: 0.7;
  }

  /* ── Animations ── */
  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>
